# 硅基流动 Provider 配置示例
# 复制为 .env 后填入本地真实值；.env 已被 .gitignore 忽略，请勿提交真实 Key。
# 也可改用 Streamlit secrets：在 .streamlit/secrets.toml 中以同名键配置。
# 不配置 API Key 时，页面可浏览样本与文档，但不能发起真实模型调用。
# 页面和错误信息不应展示 API Key、Authorization 请求头或完整请求头。

# 可选：部署启动时是否自动从 data/ 种子初始化 SQLite。默认启用；设为 0 可关闭。
# FINDUEVAL_AUTO_INIT_DB=1

# 必填：硅基流动 API Key
SILICONFLOW_API_KEY=

# 可选：API Base URL，默认 https://api.siliconflow.cn/v1
# SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1

# 可选：请求超时（秒）。普通模型建议 90-120；慢模型或批处理建议 180-240。
SILICONFLOW_TIMEOUT_SECONDS=180

# 可选：被测模型回答输出 token 上限。过大可能增加耗时，过小可能截断回答。
FINDUEVAL_EVAL_MAX_TOKENS=4096

# 可选：被测模型回答随机性。范围 0.0-1.0；裁判评分固定使用 0.0。
FINDUEVAL_EVAL_TEMPERATURE=0.1
